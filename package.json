{
  "name": "ios-ship-doctor-mcp",
  "version": "0.1.0",
  "description": "MCP server that diagnoses why an iOS app will be rejected by App Store review — privacy manifests, required-reason APIs, usage descriptions, dependency manifests — and fixes them.",
  "type": "module",
  "bin": {
    "ios-ship-doctor-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts"
  },
  "keywords": [
    "mcp",
    "ios",
    "app-store",
    "privacy-manifest",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fast-xml-parser": "^4.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
